{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Ashes",
  "scopeName": "source.ashes",
  "patterns": [
    { "include": "#comments" },
    { "include": "#imports" },
    { "include": "#keywords" },
    { "include": "#constants" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#operators" },
    { "include": "#identifiers" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.ashes",
          "match": "//.*$"
        }
      ]
    },
    "imports": {
      "patterns": [
        {
          "match": "^\\s*(import)\\s+([A-Z][A-Za-z0-9_]*(?:\\.[A-Z][A-Za-z0-9_]*)*)(?:\\s+(as)\\s+([A-Za-z][A-Za-z0-9_]*))?\\s*$",
          "captures": {
            "1": { "name": "keyword.control.import.ashes" },
            "2": { "name": "entity.name.namespace.ashes" },
            "3": { "name": "keyword.control.as.ashes" },
            "4": { "name": "entity.name.namespace.alias.ashes" }
          }
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.ashes",
          "match": "(?<!\\w)(let\\?|let!)(?!\\w)"
        },
        {
          "name": "keyword.control.ashes",
          "match": "\\b(let|rec|in|if|then|else|match|with|fun|type|async|await)\\b"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.boolean.ashes",
          "match": "\\b(true|false)\\b"
        },
        {
          "name": "constant.language.wildcard.ashes",
          "match": "(?<!\\w)_(?!\\w)"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.ashes",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.ashes",
              "match": "\\\\[nrt\\\"\\\\]"
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.float.ashes",
          "match": "\\b\\d+\\.\\d+"
        },
        {
          "name": "constant.numeric.integer.ashes",
          "match": "\\b\\d+\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.pipeline.ashes",
          "match": "\\|\\?>|\\|!>|\\|>"
        },
        {
          "name": "keyword.operator.ashes",
          "match": "->|::|>=|<=|==|!=|\\+|\\-|\\*|\\/|=|\\||,|\\."
        }
      ]
    },
    "identifiers": {
      "patterns": [
        {
          "name": "entity.name.type.ashes",
          "match": "\\b[A-Z][A-Za-z0-9_]*\\b"
        },
        {
          "name": "variable.other.ashes",
          "match": "\\b[a-z_][A-Za-z0-9_]*\\b"
        }
      ]
    }
  }
}
