{
  "name": "ashes-vscode",
  "displayName": "Ashes",
  "description": "Ashes programming language support",
  "version": "0.0.1",
  "publisher": "mattiashognas",
  "repository": {
    "type": "git",
    "url": "https://github.com/MattiasHognas/Ashes"
  },
  "engines": {
    "vscode": "^1.115.0",
    "node": "^20.19.0 || ^22.13.0 || >=24"
  },
  "icon": "icon.png",
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [
    "onLanguage:ashes",
    "onCommand:ashes.getCompilerPath",
    "onCommand:ashes.compile",
    "onCommand:ashes.run",
    "onCommand:ashes.test",
    "onCommand:ashes.installToolchain",
    "onDebugResolve:ashes"
  ],
  "capabilities": {
    "untrustedWorkspaces": {
      "supported": false,
      "description": "Ashes requires a trusted workspace because it downloads and executes external toolchain binaries."
    }
  },
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "ashes",
        "aliases": [
          "Ashes",
          "ashes"
        ],
        "extensions": [
          ".ash"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "ashes",
        "scopeName": "source.ashes",
        "path": "./syntaxes/ashes.tmLanguage.json"
      }
    ],
    "configurationDefaults": {
      "[ashes]": {
        "editor.defaultFormatter": "mattiashognas.ashes-vscode",
        "editor.formatOnSave": true
      }
    },
    "configuration": {
      "title": "Ashes",
      "properties": {
        "ashes.debugger": {
          "type": "string",
          "enum": [
            "gdb",
            "lldb"
          ],
          "default": "gdb",
          "description": "The native debugger backend used by the Ashes DAP server. Use 'gdb' (default) on Linux/Windows, or 'lldb' on Linux when an MI-compatible LLDB frontend is available."
        },
        "ashes.lspServerPath": {
          "type": "string",
          "default": "",
          "description": "Override the path to the Ashes language server executable. When set, the extension uses this binary instead of downloading one. Useful for local development."
        },
        "ashes.dapServerPath": {
          "type": "string",
          "default": "",
          "description": "Override the path to the Ashes DAP server executable. When set, the extension uses this binary instead of downloading one. Useful for local development."
        },
        "ashes.compilerPath": {
          "type": "string",
          "default": "",
          "description": "Override the path to the Ashes compiler executable. When set, the extension uses this binary instead of downloading one. Useful for local development."
        },
        "ashes.autoStartLanguageServer": {
          "type": "boolean",
          "default": true,
          "description": "Automatically start the Ashes language server when an .ash file is opened. When disabled, the extension will not start the language server automatically."
        }
      }
    },
    "commands": [
      {
        "command": "ashes.compile",
        "title": "Compile",
        "category": "Ashes"
      },
      {
        "command": "ashes.run",
        "title": "Run",
        "category": "Ashes"
      },
      {
        "command": "ashes.test",
        "title": "Run Tests",
        "category": "Ashes"
      },
      {
        "command": "ashes.installToolchain",
        "title": "Install Toolchain",
        "category": "Ashes"
      }
    ],
    "keybindings": [
      {
        "command": "ashes.run",
        "key": "ctrl+f5",
        "when": "editorLangId == ashes && !inDebugMode"
      },
      {
        "command": "ashes.compile",
        "key": "shift+f5",
        "when": "editorLangId == ashes"
      }
    ],
    "debuggers": [
      {
        "type": "ashes",
        "label": "Ashes Debug",
        "languages": [
          "ashes"
        ],
        "configurationAttributes": {
          "launch": {
            "required": [
              "program"
            ],
            "properties": {
              "program": {
                "type": "string",
                "description": "Path to the compiled Ashes binary (compiled with --debug).",
                "default": "${workspaceFolder}/out/${workspaceFolderBasename}"
              },
              "args": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "description": "Arguments to pass to the program.",
                "default": []
              },
              "cwd": {
                "type": "string",
                "description": "Working directory for the program.",
                "default": "${workspaceFolder}"
              },
              "stopOnEntry": {
                "type": "boolean",
                "description": "Stop at the entry point of the program.",
                "default": false
              },
              "debuggerPath": {
                "type": "string",
                "description": "Path to the debugger binary. Defaults to 'gdb'. For debuggerType 'lldb', the DAP server first tries 'lldb-mi' and then tries 'lldb --interpreter=mi2' on MI-capable LLDB builds.",
                "default": ""
              },
              "debuggerType": {
                "type": "string",
                "enum": [
                  "gdb",
                  "lldb"
                ],
                "description": "The native debugger backend to use. Overrides the ashes.debugger extension setting for this configuration.",
                "default": ""
              }
            }
          }
        },
        "configurationSnippets": [
          {
            "label": "Ashes: Launch",
            "description": "Launch and debug an Ashes program compiled with --debug",
            "body": {
              "name": "Ashes: Launch",
              "type": "ashes",
              "request": "launch",
              "program": "${workspaceFolder}/out/${workspaceFolderBasename}",
              "cwd": "${workspaceFolder}",
              "stopOnEntry": false
            }
          }
        ]
      }
    ],
    "breakpoints": [
      {
        "language": "ashes"
      }
    ]
  },
  "scripts": {
    "lint": "eslint \"src/**/*.ts\" --max-warnings 0",
    "lint:fix": "npm run lint -- --fix",
    "format": "prettier --write \"**/*.{ts,json,md,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{ts,json,md,yml,yaml}\"",
    "compile": "tsc -p ./ --noEmit && esbuild src/extension.ts --bundle --platform=node --external:vscode --format=cjs --outfile=out/extension.js",
    "pretest:integration": "tsc -p ./tsconfig.test.json && esbuild src/extension.ts --bundle --platform=node --external:vscode --format=cjs --outfile=out/extension.js",
    "test:integration": "node ./out/test/runTest.js"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.8",
    "@types/mocha": "^10.0.10",
    "@types/node": "^25.6.0",
    "@types/vscode": "^1.115.0",
    "@typescript-eslint/eslint-plugin": "^8.58.1",
    "@typescript-eslint/parser": "^8.58.2",
    "@vscode/test-electron": "^2.5.2",
    "esbuild": "^0.28.0",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "mocha": "^11.7.5",
    "prettier": "^3.8.3",
    "typescript": "^5.5.3"
  },
  "dependencies": {
    "adm-zip": "^0.5.17",
    "vscode-languageclient": "^9.0.1"
  },
  "overrides": {
    "minimatch": "10.2.1"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
