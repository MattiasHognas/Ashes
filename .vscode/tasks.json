{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "ashes: compile (debug)",
      "type": "shell",
      "command": "${command:ashes.getCompilerPath}",
      "args": [
        "compile",
        "--debug",
        "${file}",
        "-o",
        "${workspaceFolder}/out/${workspaceFolderBasename}"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": []
    }
  ]
}