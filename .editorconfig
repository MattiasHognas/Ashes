# Top-most EditorConfig file
root = true

# Applies to all C# files
[*.cs]

# Indentation
indent_style = space
indent_size = 4
tab_width = 4

# Newlines
end_of_line = lf
insert_final_newline = true

# Third-party analyzer severities

# These must live under [*.cs] to apply. (NOTE: the dotnet_style_*/csharp_style_*
# and MA-severity block further down is mis-scoped under [*.{csproj,props,targets}]
# and has never applied to C# — a separate pre-existing fix.)
# File-name-must-match-type: repo intentionally uses topic partial-class files
# (e.g. LlvmCodegenBuiltins.Async.cs holding `partial class LlvmCodegen`).
dotnet_diagnostic.MA0048.severity = none
# Method length: enforce MA0051 (60 lines / 40 statements) as a build-breaking warning.
dotnet_diagnostic.MA0051.severity = warning
# Defer to Meziantou MA0051 on the method-length overlap (S138 is Sonar's version).
dotnet_diagnostic.S138.severity = none

# Rules disabled as inappropriate for a performance-sensitive compiler

# Loop -> LINQ: LINQ allocates; hot-path loops are deliberate.
dotnet_diagnostic.S3267.severity = none
# `unsafe` is intentional (LLVM / P-Invoke interop), not a defect to review.
dotnet_diagnostic.S6640.severity = none
# Type name matching its namespace's last segment is idiomatic here
# (namespace Ashes.Formatter + class Formatter); renaming is disruptive.
dotnet_diagnostic.MA0049.severity = none

# Deferred (visible as suggestions; ratchet to warning over time)

dotnet_diagnostic.S1871.severity = suggestion  # identical branches (often intentional match arms)
dotnet_diagnostic.S2325.severity = suggestion  # make method static
dotnet_diagnostic.S1481.severity = suggestion  # unused local
dotnet_diagnostic.S1144.severity = suggestion  # unused private member
dotnet_diagnostic.S125.severity = suggestion   # commented-out code
dotnet_diagnostic.S1172.severity = suggestion  # unused parameter
dotnet_diagnostic.MA0016.severity = suggestion # prefer collection abstraction in return
dotnet_diagnostic.MA0008.severity = suggestion # add StructLayoutAttribute
dotnet_diagnostic.S3241.severity = suggestion  # return value never used
dotnet_diagnostic.S2365.severity = suggestion  # property makes a collection copy
dotnet_diagnostic.S4136.severity = suggestion  # group method overloads
dotnet_diagnostic.S3358.severity = suggestion  # nested ternary
dotnet_diagnostic.S1199.severity = suggestion  # nested code block
dotnet_diagnostic.S6966.severity = suggestion  # prefer async overload
dotnet_diagnostic.S5443.severity = suggestion  # shared temp directory
dotnet_diagnostic.S4200.severity = suggestion  # wrap native call
dotnet_diagnostic.S1066.severity = suggestion  # merge collapsible if
dotnet_diagnostic.S4144.severity = suggestion  # identical method bodies
dotnet_diagnostic.S1643.severity = suggestion  # use StringBuilder
dotnet_diagnostic.S127.severity = suggestion   # for-loop stop condition
dotnet_diagnostic.MA0158.severity = suggestion
dotnet_diagnostic.MA0023.severity = suggestion
dotnet_diagnostic.MA0046.severity = suggestion
dotnet_diagnostic.MA0004.severity = suggestion  # ConfigureAwait: low value for a non-UI CLI/LSP; ratchet later
dotnet_diagnostic.S108.severity = suggestion    # empty block (often intentional)
dotnet_diagnostic.S5034.severity = suggestion   # ValueTask consumed once (needs case review)
dotnet_diagnostic.S2486.severity = suggestion   # swallowed exception (needs case-by-case review)
dotnet_diagnostic.S1905.severity = suggestion   # redundant cast (risky to strip in generic type code)
dotnet_diagnostic.S1854.severity = suggestion   # dead store (side-effecting lexer/codegen calls)
dotnet_diagnostic.MA0047.severity = suggestion  # top-level type not in a namespace (CLI app)
dotnet_diagnostic.S3903.severity = suggestion   # move type into named namespace (CLI app)
dotnet_diagnostic.S3871.severity = suggestion   # exception should be public (internal CLI exceptions)
dotnet_diagnostic.S2094.severity = suggestion   # empty record (intentional DAP marker bodies)
dotnet_diagnostic.S2234.severity = suggestion   # parameter order (review case-by-case)
dotnet_diagnostic.MA0009.severity = suggestion  # regex timeout: inputs are trusted (source/protocol/tests), not adversarial
dotnet_diagnostic.S1994.severity = suggestion   # for-loop condition
dotnet_diagnostic.S3881.severity = suggestion   # IDisposable pattern
dotnet_diagnostic.S6608.severity = suggestion   # indexing over First/Last (test code)
dotnet_diagnostic.MA0084.severity = suggestion  # local hides outer symbol

# Generated EF Core migrations are machine-written; exempt from method-length limits
# and from doc-coverage enforcement.
[src/Ashes.Registry/Storage/Migrations/*.cs]
dotnet_diagnostic.MA0051.severity = none
dotnet_diagnostic.CS1591.severity = none

# Test projects: public test classes are a framework requirement, not a documented API.
[src/Ashes.Tests/**.cs]
dotnet_diagnostic.CS1591.severity = none

[src/Ashes.*.Tests/**.cs]
dotnet_diagnostic.CS1591.severity = none

# LLVM interop mirrors the LLVM C API one-to-one; a file-level summary covers the shape.
[src/Ashes.Backend/Llvm/Interop/**.cs]
dotnet_diagnostic.CS1591.severity = none

[*.txt]
insert_final_newline = false

[*.ash]
indent_style = space
indent_size = 4
tab_width = 4
end_of_line = lf

[*.{csproj,props,targets}]
indent_style = space
indent_size = 2
tab_width = 2
end_of_line = lf
insert_final_newline = true

# Nullable analysis is enabled in build; keep style consistent
dotnet_style_null_propagation = true:suggestion
dotnet_style_coalesce_expression = true:suggestion

# Prefer explicit types in compiler code (less ambiguity in AST/IR)
dotnet_style_var_for_built_in_types = false:warning
dotnet_style_var_when_type_is_apparent = false:warning
dotnet_style_var_elsewhere = false:warning

# Prefer expression-bodied members sparingly (readability for compiler logic)
csharp_style_expression_bodied_methods = false:warning
csharp_style_expression_bodied_constructors = false:warning
csharp_style_expression_bodied_operators = false:warning
csharp_style_expression_bodied_properties = when_on_single_line:suggestion

# Use pattern matching where clear
csharp_style_pattern_matching_over_is_with_cast_check = true:suggestion
csharp_style_pattern_matching_over_as_with_null_check = true:suggestion

# Use switch expressions where appropriate
csharp_style_prefer_switch_expression = true:suggestion

# Prefer readonly where possible (helps avoid defensive copies)
dotnet_style_readonly_field = true:warning

# Prefer 'in' parameters for large structs (Meziantou can suggest)
dotnet_diagnostic.MA0032.severity = warning

# Disallow culture-sensitive string comparisons by default
# Use StringComparison.Ordinal or OrdinalIgnoreCase explicitly
dotnet_diagnostic.MA0006.severity = error

# Dispose pattern correctness
dotnet_diagnostic.MA0004.severity = warning

# Avoid allocation-heavy LINQ in hot paths
dotnet_diagnostic.MA0011.severity = warning

# Prefer using declarations where possible
csharp_style_prefer_using_declaration = true:suggestion

# Remove unused private members
dotnet_diagnostic.IDE0051.severity = warning

# Braces for clarity
csharp_prefer_braces = true:warning

# Naming (keep minimal to avoid noise)
dotnet_naming_rule.private_fields_should_be_camel_case.severity = suggestion
dotnet_naming_rule.private_fields_should_be_camel_case.symbols = private_fields
dotnet_naming_rule.private_fields_should_be_camel_case.style = camel_case_style

dotnet_naming_symbols.private_fields.applicable_kinds = field
dotnet_naming_symbols.private_fields.applicable_accessibilities = private

dotnet_naming_style.camel_case_style.capitalization = camel_case

# Analyzer severities can be tuned here over time
