<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <AssemblyName>Ashes.Backend</AssemblyName>
    <RootNamespace>Ashes.Backend</RootNamespace>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\Ashes.Semantics\Ashes.Semantics.csproj" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="LibObjectFile" Version="2.1.0" />
  </ItemGroup>

  <ItemGroup>
    <None Include="..\..\runtimes\win-x64\libLLVM.dll"
          Condition="Exists('..\..\runtimes\win-x64\libLLVM.dll')"
          CopyToOutputDirectory="PreserveNewest"
          Link="libLLVM.dll" />
    <None Include="..\..\runtimes\linux-x64\libLLVM.so"
          Condition="Exists('..\..\runtimes\linux-x64\libLLVM.so')"
          CopyToOutputDirectory="PreserveNewest"
          Link="libLLVM.so" />
  </ItemGroup>

</Project>
