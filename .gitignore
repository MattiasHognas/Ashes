## A streamlined .gitignore for modern .NET projects
## including temporary files, build results, and
## files generated by popular .NET tools. If you are
## developing with Visual Studio, the VS .gitignore
## https://github.com/github/gitignore/blob/main/VisualStudio.gitignore
## has more thorough IDE-specific entries.
##
## Get latest from https://github.com/github/gitignore/blob/main/Dotnet.gitignore

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Ww][Ii][Nn]32/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/

# .NET Core
project.lock.json
project.fragment.lock.json
artifacts/

# ASP.NET Scaffolding
ScaffoldingReadMe.txt

# NuGet Packages
*.nupkg
# NuGet Symbol Packages
*.snupkg

# Others
~$*
*~
CodeCoverage/

# MSBuild Binary and Structured Log
*.binlog

# Test Results
[Tt]est[Rr]esult*/


# VS Code extension
.pnpm-store
vscode-extension/package-lock.json
vscode-extension/node_modules/
vscode-extension/out/
vscode-extension/compiler/
vscode-extension/lsp-server/
vscode-extension/dap-server/
*.vsix
.vscode-test/
# Native binaries emitted by the real-compiler integration tests (named after
# the .ash fixture they compile) — build artifacts, never source.
vscode-extension/src/test/fixtures/error
vscode-extension/src/test/fixtures/hello
vscode-extension/src/test/fixtures/types

# Publish output
dist/
publish/

# Builds
.pnpm-store/
tests/*.exe
examples/*.exe
/*.exe
/*.txt
/*.log

# 1BRC challenge: downloaded data + compiled binary (the .ash source is tracked).
# The root-anchored rules above do not reach into challenges/.
challenges/measurements*.txt
challenges/*.exe
challenges/brc
*.received.txt
runtimes/*
!runtimes/linux-x64/
!runtimes/linux-arm64/
!runtimes/win-x64/
runtimes/linux-x64/*
!runtimes/linux-x64/librustls.so
!runtimes/linux-x64/rustls.version
runtimes/linux-arm64/*
!runtimes/linux-arm64/librustls.so
!runtimes/linux-arm64/rustls.version
runtimes/win-x64/*
!runtimes/win-x64/rustls.dll
!runtimes/win-x64/rustls.version
out
*.lscache
*.core

# Workfiles
_*.sh
_*.md
/*.sh
.orchestrator/
backlog.json
*.csv

# Git
.git/

# Local CI/CD (ci/) outputs
staging/
.ci-cache/
