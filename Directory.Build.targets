<Project>
  <!--
    During 'dotnet publish' with a cross-architecture runtime, project reference evaluation may
    resolve the wrong-arch libLLVM.so (from _HostLinuxRid fallback in Backend.csproj).
    This target runs after Publish to ensure the correct RID-specific native library
    is placed alongside the published executable.
  -->
  <Target Name="_EnsureCorrectNativeLibForPublish"
          AfterTargets="Publish"
          Condition="'$(RuntimeIdentifier)' != ''">
    <Copy SourceFiles="$(MSBuildThisFileDirectory)runtimes\$(RuntimeIdentifier)\libLLVM.so"
          DestinationFiles="$(PublishDir)libLLVM.so"
          SkipUnchangedFiles="false"
          Condition="$(RuntimeIdentifier.StartsWith('linux-')) and Exists('$(MSBuildThisFileDirectory)runtimes\$(RuntimeIdentifier)\libLLVM.so')" />
    <Copy SourceFiles="$(MSBuildThisFileDirectory)runtimes\$(RuntimeIdentifier)\libLLVM.dll"
          DestinationFiles="$(PublishDir)libLLVM.dll"
          SkipUnchangedFiles="false"
          Condition="$(RuntimeIdentifier.StartsWith('win-')) and Exists('$(MSBuildThisFileDirectory)runtimes\$(RuntimeIdentifier)\libLLVM.dll')" />
  </Target>
</Project>
