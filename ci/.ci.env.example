# Copy to ci/.ci.env (git-ignored) and edit to override S3/MinIO settings.
# Defaults below target the local MinIO container started by `just minio-up`.

# CI_S3_ENDPOINT=http://localhost:9000   # AWS later: https://s3.<region>.amazonaws.com
# CI_S3_BUCKET=ashes
# CI_S3_ACCESS_KEY=minioadmin
# CI_S3_SECRET_KEY=minioadmin

# Use Docker instead of Podman:
# CI_ENGINE=docker
